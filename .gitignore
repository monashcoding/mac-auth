# Secrets — never commit the real env file.
.env
*.env
!.env.example

# Local-only dev override (exposes port 3000, points at localhost — must never
# reach the shared server).
docker-compose.override.yml

# Dependencies
node_modules/

# Build output
auth/dist/
dist/

# Generated Drizzle migrations (generated during the Docker build).
auth/drizzle/

# Database backups produced at runtime.
backups/

# Logs / OS cruft
*.log
.DS_Store
